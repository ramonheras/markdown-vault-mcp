# Markdown Vault MCP environment variables (copy to .env and fill in).

# --- Server ---
# MARKDOWN_VAULT_MCP_TRANSPORT=stdio   # stdio | http | sse
# MARKDOWN_VAULT_MCP_HOST=127.0.0.1
# MARKDOWN_VAULT_MCP_PORT=8000
# MARKDOWN_VAULT_MCP_HTTP_PATH=/mcp
# MARKDOWN_VAULT_MCP_BASE_URL=https://mcp.example.com

# --- Auth (pick one flavor) ---
# MARKDOWN_VAULT_MCP_BEARER_TOKEN=<secret>

# MARKDOWN_VAULT_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
# MARKDOWN_VAULT_MCP_OIDC_CLIENT_ID=<client-id>
# MARKDOWN_VAULT_MCP_OIDC_CLIENT_SECRET=<client-secret>
# MARKDOWN_VAULT_MCP_OIDC_AUDIENCE=
# MARKDOWN_VAULT_MCP_OIDC_REQUIRED_SCOPES=openid
# MARKDOWN_VAULT_MCP_OIDC_JWT_SIGNING_KEY=<hex-string>

# --- Domain ---
# Core vault and index paths
# MARKDOWN_VAULT_MCP_SOURCE_DIR=/data/vault
# MARKDOWN_VAULT_MCP_INDEX_PATH=/data/state/index.sqlite
# MARKDOWN_VAULT_MCP_EMBEDDINGS_PATH=/data/state/embeddings.npy
# MARKDOWN_VAULT_MCP_READ_ONLY=false
# MARKDOWN_VAULT_MCP_EXCLUDE=.obsidian/*,.trash/*

# Embeddings / semantic search
# MARKDOWN_VAULT_MCP_EMBEDDING_PROVIDER=fastembed
# MARKDOWN_VAULT_MCP_FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
# MARKDOWN_VAULT_MCP_FASTEMBED_CACHE_DIR=/data/state/fastembed-cache

# Attachments
# MARKDOWN_VAULT_MCP_ATTACHMENT_EXTENSIONS=png,jpg,jpeg,pdf,gif,webp
# MARKDOWN_VAULT_MCP_MAX_ATTACHMENT_SIZE_MB=10

# Git write-through (optional)
# MARKDOWN_VAULT_MCP_GIT_REPO_URL=https://github.com/you/vault.git
# MARKDOWN_VAULT_MCP_GIT_TOKEN=<pat>

# GitHub webhook — triggers immediate pull+reindex on push (HTTP/SSE only)
# MARKDOWN_VAULT_MCP_GITHUB_WEBHOOK_SECRET=<random-secret>

# File watcher — detects external file changes for non-git vaults (requires watchdog extra)
# MARKDOWN_VAULT_MCP_FILE_WATCHER=true
# MARKDOWN_VAULT_MCP_FILE_WATCHER_DEBOUNCE_S=2.0

# HTTP transport extras
# MARKDOWN_VAULT_MCP_EVENT_STORE_URL=file:///data/state/events
# MARKDOWN_VAULT_MCP_APP_DOMAIN=
