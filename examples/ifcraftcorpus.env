# IF Craft Corpus — strict frontmatter, read-only
# MARKDOWN_VAULT_MCP_SERVER_NAME=ifcraft-corpus
MARKDOWN_VAULT_MCP_INSTRUCTIONS=Interactive Fiction craft corpus (read-only). Curated articles on narrative design, worldbuilding, and prose style. All documents have required fields: title and cluster. Use 'list_tags' with field='cluster' or field='topics' to discover filter values. Keyword search only — semantic search is not configured.
MARKDOWN_VAULT_MCP_SOURCE_DIR=/data/corpus
MARKDOWN_VAULT_MCP_READ_ONLY=true
MARKDOWN_VAULT_MCP_REQUIRED_FIELDS=title,cluster
MARKDOWN_VAULT_MCP_INDEXED_FIELDS=cluster,topics

# Attachments: uncomment to enable attachment access alongside corpus documents.
# MARKDOWN_VAULT_MCP_ATTACHMENT_EXTENSIONS=pdf,png
# Maximum attachment size in MB returned by read() / accepted by write().
# Default 1 MB (lowered from 10 MB to keep LLM context bounded).
# Set to 0 to disable the limit.
# MARKDOWN_VAULT_MCP_MAX_ATTACHMENT_SIZE_MB=1
# Maximum bytes returned by full-document read() for .md files.
# Default 262144 (256 KB).  Use read(path, section=...) for partial reads.
# Set to 0 to disable the limit.
# MARKDOWN_VAULT_MCP_MAX_NOTE_READ_BYTES=262144

# Optional: override Claude app domain for MCP Apps iframe sandboxing (auto-computed from BASE_URL)
# MARKDOWN_VAULT_MCP_APP_DOMAIN=
