# Obsidian vault — read-only with OIDC authentication (Authelia / any OIDC provider)
#
# Prerequisites:
#   1. Use --transport http (streamable-http).  OIDC auth requires HTTP transport.
#   2. Register a client in your OIDC provider (see Authelia snippet below).
#   3. Set MARKDOWN_VAULT_MCP_OIDC_JWT_SIGNING_KEY — required on Linux/Docker to
#      survive restarts without forcing client re-authentication.
#
# Authelia configuration.yml client registration:
#
#   identity_providers:
#     oidc:
#       clients:
#         - client_id: markdown-vault-mcp
#           client_secret: '$pbkdf2-sha512$...'   # use authelia crypto hash generate
#           redirect_uris:
#             - https://mcp.example.com/auth/callback
#             - https://mcp.example.com/vault/auth/callback   # when mounted under /vault
#           grant_types:
#             - authorization_code
#           response_types:
#             - code
#           pkce_challenge_method: S256
#           scopes:
#             - openid
#             - profile
#             - email
#
# Generate a signing key:  openssl rand -hex 32

MARKDOWN_VAULT_MCP_SERVER_NAME=obsidian-vault
MARKDOWN_VAULT_MCP_INSTRUCTIONS=Personal Obsidian vault. Paths are relative (e.g. 'Journal/note.md'). Use 'search' with mode='hybrid' for best results.
MARKDOWN_VAULT_MCP_SOURCE_DIR=/data/vault
MARKDOWN_VAULT_MCP_READ_ONLY=true
MARKDOWN_VAULT_MCP_EXCLUDE=.obsidian/**,.trash/**,_templates/**
# Optional HTTP subpath mount (default: /mcp).
# For non-OIDC subpath: set to /vault/mcp and route directly.
# For OIDC subpath: keep at /mcp and put the subpath in BASE_URL instead.
# MARKDOWN_VAULT_MCP_HTTP_PATH=/mcp

# --- OIDC auth (all four required to enable) ---
MARKDOWN_VAULT_MCP_BASE_URL=https://mcp.example.com
# If mounted under /vault, set BASE_URL with the subpath (HTTP_PATH stays /mcp):
# MARKDOWN_VAULT_MCP_BASE_URL=https://mcp.example.com/vault
MARKDOWN_VAULT_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
MARKDOWN_VAULT_MCP_OIDC_CLIENT_ID=markdown-vault-mcp
MARKDOWN_VAULT_MCP_OIDC_CLIENT_SECRET=your-client-secret-here

# Persistent JWT signing key — required on Linux/Docker
# Generate: openssl rand -hex 32
MARKDOWN_VAULT_MCP_OIDC_JWT_SIGNING_KEY=your-random-hex-secret-here

# Optional: request additional scopes (default: openid)
# MARKDOWN_VAULT_MCP_OIDC_REQUIRED_SCOPES=openid,profile,email

# Optional: audience claim if your provider requires it
# MARKDOWN_VAULT_MCP_OIDC_AUDIENCE=

# Optional: verify access token as JWT instead of id token (default: false).
# Only needed for providers with JWT access tokens where audience validation matters.
# MARKDOWN_VAULT_MCP_OIDC_VERIFY_ACCESS_TOKEN=true

# --- MCP Apps (optional) ---
# Override the Claude app domain used for MCP Apps iframe sandboxing.
# Auto-computed from BASE_URL when not set.
# MARKDOWN_VAULT_MCP_APP_DOMAIN=

# --- HTTP session persistence (optional) ---
# Unified KV backend; default file:///data/state survives restarts
# MARKDOWN_VAULT_MCP_KV_STORE_URL=file:///data/state

# --- Attachments (optional) ---
# Maximum attachment size in MB returned by read() / accepted by write().
# Default 1 MB (lowered from 10 MB to keep LLM context bounded).
# Set to 0 to disable the limit.
# MARKDOWN_VAULT_MCP_MAX_ATTACHMENT_SIZE_MB=1
# Maximum bytes returned by full-document read() for .md files.
# Default 262144 (256 KB).  Use read(path, section=...) for partial reads.
# Set to 0 to disable the limit.
# MARKDOWN_VAULT_MCP_MAX_NOTE_READ_BYTES=262144

# --- Embeddings (optional) ---
MARKDOWN_VAULT_MCP_EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
MARKDOWN_VAULT_MCP_OLLAMA_MODEL=nomic-embed-text

# Structured (one-JSON-object-per-record) logs for log aggregators —
# recommended in production. Default is rich key=value text.
# FASTMCP_ENABLE_RICH_LOGGING=false
