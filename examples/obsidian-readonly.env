# Obsidian vault — read-only with Ollama embeddings
# MARKDOWN_VAULT_MCP_SERVER_NAME=obsidian-vault
MARKDOWN_VAULT_MCP_INSTRUCTIONS=Personal Obsidian knowledge base (read-only). Contains notes, journal entries, and project references. Semantic search available — use mode='hybrid' for best results. Write tools are NOT available on this instance.
MARKDOWN_VAULT_MCP_SOURCE_DIR=/home/user/Obsidian
MARKDOWN_VAULT_MCP_READ_ONLY=true
MARKDOWN_VAULT_MCP_EXCLUDE=.obsidian/**,.trash/**,_templates/**

# Periodic git sync (ff-only). Default is 600s; set to 0 to disable.
# MARKDOWN_VAULT_MCP_GIT_PULL_INTERVAL_S=600
# Optional managed mode for pull-only startup sync from a remote checkout.
# MARKDOWN_VAULT_MCP_GIT_REPO_URL=https://github.com/your-org/your-vault.git

# Attachments: default list allows common document and image formats.
# Uncomment to restrict to specific extensions, or use * for all non-.md files.
# MARKDOWN_VAULT_MCP_ATTACHMENT_EXTENSIONS=pdf,png,jpg,jpeg
# MARKDOWN_VAULT_MCP_MAX_ATTACHMENT_SIZE_MB=10

# Optional: override Claude app domain for MCP Apps iframe sandboxing (auto-computed from BASE_URL)
# MARKDOWN_VAULT_MCP_APP_DOMAIN=

MARKDOWN_VAULT_MCP_EMBEDDING_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
MARKDOWN_VAULT_MCP_OLLAMA_MODEL=nomic-embed-text

# --- Search ranking and snippet truncation ---
# Per-document result cap. 0 rejected. Per-call override via search tool.
# MARKDOWN_VAULT_MCP_CHUNKS_PER_DOC=2

# Snippet word budget. 0 = no truncation, full chunk. Per-call override.
# MARKDOWN_VAULT_MCP_SNIPPET_WORDS=200

# Length downweight strength. 0 disables. Operator-only (no per-call override).
# MARKDOWN_VAULT_MCP_LENGTH_DOWNWEIGHT_ALPHA=0.25

# Adaptive chunker word threshold. Reindex required when changed.
# Set very high (e.g. 100000) to disable adaptive splitting.
# MARKDOWN_VAULT_MCP_MAX_CHUNK_WORDS=400
