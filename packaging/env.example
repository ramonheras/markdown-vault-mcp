# /etc/markdown-vault-mcp/env — EnvironmentFile for the systemd service.
# Uncomment and edit settings as needed. Lines starting with # are ignored.
# See https://pvliesdonk.github.io/markdown-vault-mcp/configuration/ for full docs.

# ---------------------------------------------------------------------------
# Core (required)
# ---------------------------------------------------------------------------

# Path to the markdown vault directory.
MARKDOWN_VAULT_MCP_SOURCE_DIR=/var/lib/markdown-vault-mcp/vault

# Read-only mode disables all write tools. (default: true)
#MARKDOWN_VAULT_MCP_READ_ONLY=true

# ---------------------------------------------------------------------------
# Index & State
# ---------------------------------------------------------------------------

# Path to the persistent SQLite FTS5 index file. Unset = in-memory.
MARKDOWN_VAULT_MCP_INDEX_PATH=/var/lib/markdown-vault-mcp/index.db

# Base path for vector embeddings sidecar files (.npy + .json). Unset = disabled.
#MARKDOWN_VAULT_MCP_EMBEDDINGS_PATH=/var/lib/markdown-vault-mcp/embeddings

# Path to the hash-state JSON file. Unset = {source_dir}/.markdown_vault_mcp/state.json.
#MARKDOWN_VAULT_MCP_STATE_PATH=/var/lib/markdown-vault-mcp/state.json

# ---------------------------------------------------------------------------
# Frontmatter & Filtering
# ---------------------------------------------------------------------------

# Comma-separated frontmatter fields to index in document_tags table.
#MARKDOWN_VAULT_MCP_INDEXED_FIELDS=tags,category

# Comma-separated required frontmatter fields. Documents missing these are skipped.
#MARKDOWN_VAULT_MCP_REQUIRED_FIELDS=

# Comma-separated glob patterns to exclude from scanning.
#MARKDOWN_VAULT_MCP_EXCLUDE=.obsidian/**,_templates/**

# ---------------------------------------------------------------------------
# Git Integration
# ---------------------------------------------------------------------------

# Personal access token (PAT) or app token for git push/pull.
#MARKDOWN_VAULT_MCP_GIT_TOKEN=

# HTTPS remote URL for managed-repo mode (startup may clone into SOURCE_DIR).
#MARKDOWN_VAULT_MCP_GIT_REPO_URL=

# Username for token-based auth. (default: x-access-token)
#MARKDOWN_VAULT_MCP_GIT_USERNAME=x-access-token

# Seconds of idle before pushing commits. 0 = push only on shutdown. (default: 30)
#MARKDOWN_VAULT_MCP_GIT_PUSH_DELAY_S=30

# Git committer identity for auto-commits.
#MARKDOWN_VAULT_MCP_GIT_COMMIT_NAME=markdown-vault-mcp
#MARKDOWN_VAULT_MCP_GIT_COMMIT_EMAIL=noreply@markdown-vault-mcp

# Run "git lfs pull" during git strategy init. (default: true)
#MARKDOWN_VAULT_MCP_GIT_LFS=true

# Seconds between periodic git fetch + ff-only updates. 0 = disabled. (default: 600)
#MARKDOWN_VAULT_MCP_GIT_PULL_INTERVAL_S=600

# ---------------------------------------------------------------------------
# Attachments
# ---------------------------------------------------------------------------

# Comma-separated allowed attachment extensions (without dot). Use * for all.
#MARKDOWN_VAULT_MCP_ATTACHMENT_EXTENSIONS=pdf,png,jpg,jpeg,gif,svg,webp

# Maximum attachment size in MB. 0 = unlimited. (default: 10.0)
#MARKDOWN_VAULT_MCP_MAX_ATTACHMENT_SIZE_MB=10.0

# ---------------------------------------------------------------------------
# Templates & Prompts
# ---------------------------------------------------------------------------

# Relative folder for note template markdown files. (default: _templates)
#MARKDOWN_VAULT_MCP_TEMPLATES_FOLDER=_templates

# Absolute or relative path to user-defined prompt files. Unset = disabled.
#MARKDOWN_VAULT_MCP_PROMPTS_FOLDER=

# ---------------------------------------------------------------------------
# Embeddings Provider
# ---------------------------------------------------------------------------

# Embedding provider: "fastembed" (local), "openai", or "ollama". Unset = auto-detect.
#MARKDOWN_VAULT_MCP_EMBEDDING_PROVIDER=fastembed

# FastEmbed model name (used when MARKDOWN_VAULT_MCP_EMBEDDING_PROVIDER=fastembed or auto-detected).
#MARKDOWN_VAULT_MCP_FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# FastEmbed model cache directory. Important for systemd: ProtectHome=yes blocks
# the default ~/.cache path. (default: ~/.cache/fastembed)
#MARKDOWN_VAULT_MCP_FASTEMBED_CACHE_DIR=/var/lib/markdown-vault-mcp/fastembed-cache

# OpenAI API key (required when MARKDOWN_VAULT_MCP_EMBEDDING_PROVIDER=openai or auto-detection).
#OPENAI_API_KEY=

# Ollama server URL. (default: http://localhost:11434)
#OLLAMA_HOST=http://localhost:11434

# Ollama embedding model name. (default: nomic-embed-text)
#MARKDOWN_VAULT_MCP_OLLAMA_MODEL=nomic-embed-text

# Force Ollama CPU-only mode. (default: false)
#MARKDOWN_VAULT_MCP_OLLAMA_CPU_ONLY=false

# ---------------------------------------------------------------------------
# Server Identity & Logging
# ---------------------------------------------------------------------------

# MCP server display name. (default: markdown-vault-mcp)
#MARKDOWN_VAULT_MCP_SERVER_NAME=markdown-vault-mcp

# Custom LLM-facing server instructions (overrides built-in text).
#MARKDOWN_VAULT_MCP_INSTRUCTIONS=

# HTTP endpoint path prefix. (default: /mcp)
#MARKDOWN_VAULT_MCP_HTTP_PATH=/mcp

# Log level for FastMCP internals: DEBUG, INFO, WARNING, ERROR.
# App loggers default to INFO. -v overrides both to DEBUG. (default: INFO)
#FASTMCP_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Authentication (optional — leave all unset for no auth)
# ---------------------------------------------------------------------------

# Simple bearer token auth. When set, clients must present this token.
#MARKDOWN_VAULT_MCP_BEARER_TOKEN=

# Base URL for OIDC callback routing (e.g. https://mcp.example.com).
#MARKDOWN_VAULT_MCP_BASE_URL=

# OIDC discovery URL (e.g. https://auth.example.com/.well-known/openid-configuration).
#MARKDOWN_VAULT_MCP_OIDC_CONFIG_URL=

# OIDC client credentials (required for OIDC auth).
#MARKDOWN_VAULT_MCP_OIDC_CLIENT_ID=
#MARKDOWN_VAULT_MCP_OIDC_CLIENT_SECRET=

# Signing key for OIDC session JWTs. Critical on Linux — ephemeral default
# invalidates tokens on restart.
#MARKDOWN_VAULT_MCP_OIDC_JWT_SIGNING_KEY=

# OIDC audience claim for token validation.
#MARKDOWN_VAULT_MCP_OIDC_AUDIENCE=

# OIDC required scopes. (default: openid)
#MARKDOWN_VAULT_MCP_OIDC_REQUIRED_SCOPES=openid

# Verify OIDC access token as JWT instead of id_token. (default: false)
#MARKDOWN_VAULT_MCP_OIDC_VERIFY_ACCESS_TOKEN=false
