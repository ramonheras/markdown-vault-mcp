{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.pvliesdonk/markdown-vault-mcp",
  "title": "Markdown Vault MCP",
  "description": "Generic markdown vault MCP server with FTS5 + semantic search",
  "version": "1.10.0",
  "repository": {
    "url": "https://github.com/pvliesdonk/markdown-vault-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "markdown-vault-mcp",
      "version": "1.10.0",
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/pvliesdonk/markdown-vault-mcp:1.10.0",
      "transport": {
        "type": "streamable-http",
        "url": "http://localhost:{--port}/mcp"
      },
      "packageArguments": [
        {
          "type": "named",
          "name": "--port",
          "default": 8000,
          "description": "Port for the HTTP transport"
        }
      ]
    }
  ]
}
